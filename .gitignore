# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────────────────────────
/.next/
/out/
/build

# ── Electron build output ─────────────────────────────────────────────────────
/dist
/dist-electron
/release

# ── Prisma generated client (rebuilt with `npx prisma generate`) ──────────────
/app/generated/prisma

# ── Database ──────────────────────────────────────────────────────────────────
dev.db
dev.db-journal
prisma/dev.db
prisma/dev.db-journal
*.db
*.db-journal

# ── Secrets and local config ──────────────────────────────────────────────────
.env
.env.local
.env.*.local
# .env.example is intentionally NOT ignored (safe to commit — no secrets)

# ── Runtime config files (written at runtime, contain personal data/tokens) ───
.strava-config.json
.wow-raid-baseline.json
.race-config.json
.strava-tokens.json

# ── Claude Code / AI assistant files ─────────────────────────────────────────
.claude/
CLAUDE.md
AGENTS.md
.claudeignore

# ── Build resources (seeded DB used during Electron packaging) ────────────────
build-resources/*.db

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
*.pem

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing ───────────────────────────────────────────────────────────────────
/coverage

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel