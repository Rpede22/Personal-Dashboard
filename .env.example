DATABASE_URL="file:./prisma/dev.db"

# Raider.IO — no key needed (public API)

# API-Football via RapidAPI — optional, only used as fallback for football standings
# (FotMob is the primary source and needs no key)
# Sign up at rapidapi.com → search "API-Football" → subscribe to free plan (100 req/day)
RAPIDAPI_KEY=""

# Strava OAuth
# Create app at strava.com/settings/api — set Authorization Callback Domain to "localhost"
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""

# Calendar — iCloud CalDAV (fetches calendars)
# ICLOUD_CALDAV_USER: your Apple ID email
# ICLOUD_CALDAV_PASS: app-specific password from appleid.apple.com → Security → App-Specific Passwords
ICLOUD_CALDAV_USER=""
ICLOUD_CALDAV_PASS=""

# Blizzard API — for accurate per-boss raid kill detection (no user login required)
# Register at develop.battle.net → Create Client → copy Client ID + Secret
# Used in WoW sync to detect which bosses were killed this reset via last_kill_timestamp
BLIZZARD_CLIENT_ID=""
BLIZZARD_CLIENT_SECRET=""

# football-data.org — for Barcelona goal scorer timeline (La Liga covered by free tier)
# Register at football-data.org → free plan → copy API key
# Without this key, the goal timeline button is hidden in SportsTeamHub for Barcelona
FOOTBALL_DATA_KEY=""
