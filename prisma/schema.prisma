generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  dueDate   DateTime
  subject   String?
  status    String   @default("pending") // pending | in_progress | done
  priority  String   @default("medium")  // low | medium | high
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RunLog {
  id        Int      @id @default(autoincrement())
  date      DateTime
  distance  Float    // km
  duration  Int      // seconds
  feel      String?  // easy | moderate | hard
  notes     String?
  createdAt DateTime @default(now())
}

model WowCharacter {
  id        Int      @id @default(autoincrement())
  name      String
  realm     String
  region    String   @default("eu")
  createdAt DateTime @default(now())

  @@unique([name, realm, region])
}

model WowChecklist {
  id          Int      @id @default(autoincrement())
  characterId Int
  weekStart   DateTime // Monday of the reset week
  task        String
  done        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([characterId, weekStart, task])
}

model WowChecklistTemplate {
  id      Int     @id @default(autoincrement())
  task    String  @unique
  isDefault Boolean @default(false)
}
