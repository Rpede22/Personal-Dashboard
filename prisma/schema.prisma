generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  dueDate   DateTime
  dueTime   String?  // HH:MM in local time, e.g. "20:00"
  subject   String?
  status    String   @default("pending") // pending | in_progress | done | overdue
  priority  String   @default("medium")  // low | medium | high — auto-overridden by UI
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RunLog {
  id        Int      @id @default(autoincrement())
  date      DateTime
  distance  Float    // km
  duration  Int      // seconds
  notes     String?
  createdAt DateTime @default(now())
}

model RunPlan {
  id        Int      @id @default(autoincrement())
  date      DateTime
  distance  Float?   // planned km (null = rest day)
  type      String   // easy | tempo | long | rest
  notes     String?
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model WowCharacter {
  id        Int      @id @default(autoincrement())
  name      String
  realm     String
  region    String   @default("eu")
  sortOrder Int      @default(0)
  notes     String   @default("")
  createdAt DateTime @default(now())

  @@unique([name, realm, region])
}

model WowChecklist {
  id          Int      @id @default(autoincrement())
  characterId Int
  weekStart   DateTime // Wednesday reset week start
  task        String
  done        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([characterId, weekStart, task])
}

model WowChecklistTemplate {
  id        Int     @id @default(autoincrement())
  task      String  @unique
  isDefault Boolean @default(false)
}

model WowGearWishlist {
  id          Int     @id @default(autoincrement())
  characterId Int
  slot        String
  itemName    String  @default("")
  obtained    Boolean @default(false)

  @@unique([characterId, slot])
}
